FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN go build -o /out/api ./cmd/api

FROM alpine:3.20
COPY --from=build /out/api /usr/local/bin/redcart-api
COPY --from=build /src/migrations /app/migrations
ENV MIGRATIONS_DIR=/app/migrations
EXPOSE 18080
CMD ["redcart-api"]
